# Supabase pooler connection (session mode, port 5432) — direct connection
# (db.<ref>.supabase.co) is IPv6-only and won't resolve on most local networks.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-password
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_MONTHLY_PRICE_ID=price_replace_me
STRIPE_PRO_YEARLY_PRICE_ID=price_replace_me
APP_URL=http://localhost:5173
# Set these to the actual launch window before deploying. The initial campaign is 90 days.
REFERRAL_CAMPAIGN_ID=launch-2026
REFERRAL_CAMPAIGN_START=2026-07-21T00:00:00Z
REFERRAL_CAMPAIGN_END=2026-10-19T00:00:00Z
MEDIA_SIGNING_SECRET=replace-with-at-least-32-random-characters
# Generate with: openssl rand -base64 32
CRAWL_SESSION_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
CRAWL_WORKER_ID=import-worker-1
CRAWL_STALE_RUN_THRESHOLD_MS=300000
CHAT_PROFILE_ROOT=
HEADLESS=true
# App Knowledge supports chatgpt-browser or antigravity-browser.
# Antigravity reuses the signed-in desktop app and is always one lane. Leave its
# CDP endpoint empty on macOS to read Antigravity's active port automatically.
APP_KNOWLEDGE_PROVIDER=antigravity-browser
APP_KNOWLEDGE_BROWSER_CONCURRENCY=1
ANTIGRAVITY_CDP_ENDPOINT=
GENERAL_RATE_LIMIT=300
MEDIA_RATE_LIMIT=500
APP_TRAVERSAL_LIMIT=20
# Personal designer Research Projects and durable Flow-to-Feature-Document
# generation only. App Knowledge uses the dedicated ChatGPT browser settings above.
RESEARCH_PROJECTS_ENABLED=false
VITE_RESEARCH_PROJECTS_ENABLED=false
# Server/worker only. Never expose these values through VITE_* variables.
RESEARCH_LLM_BASE_URL=https://api.openai.com/v1
RESEARCH_LLM_API_KEY=
RESEARCH_LLM_MODEL=

# Adaptive catalog search. Keep both flags disabled until indexing, relevance,
# and performance gates pass. The embedding key is server/worker-only.
ADVANCED_SEARCH_ENABLED=false
VITE_ADVANCED_SEARCH_ENABLED=false
SEARCH_EMBEDDING_BASE_URL=https://api.openai.com/v1
SEARCH_EMBEDDING_API_KEY=
SEARCH_EMBEDDING_MODEL=text-embedding-3-small
SEARCH_INDEX_WORKER_ID=
