{
  "name": "astryx",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "design-systems:getdesign:dry-run": "node --env-file=.env --import tsx scripts/import-getdesign-design-systems.ts --dry-run",
    "design-systems:getdesign:apply": "node --env-file=.env --import tsx scripts/import-getdesign-design-systems.ts --apply",
    "design-systems:getdesign:rollback": "node --env-file=.env --import tsx scripts/import-getdesign-design-systems.ts --rollback",
    "crawl": "tsx src/index.ts crawl",
    "crawl-bulk": "tsx src/index.ts crawl-bulk",
    "crawl-elements": "tsx src/index.ts crawl-elements",
    "crawl-flows": "tsx src/index.ts crawl-flows",
    "export-storage-state": "tsx src/index.ts export-storage-state",
    "discover-apps": "tsx src/index.ts discover-apps",
    "migrate-sqlite-to-pg": "tsx scripts/migrate-sqlite-to-pg.ts",
    "db:migrate": "node --experimental-strip-types scripts/migrate.ts",
    "db:check": "node --experimental-strip-types scripts/check-migrations.ts",
    "db:verify": "node --experimental-strip-types scripts/verify-migrations.ts",
    "db:backup": "node --experimental-strip-types scripts/db-backup.ts",
    "db:restore-verify": "node --experimental-strip-types scripts/db-restore-verify.ts",
    "catalog-db:audit": "node --env-file=.env --import tsx scripts/merge-catalog-databases.ts --dry-run",
    "catalog-db:merge": "node --env-file=.env --import tsx scripts/merge-catalog-databases.ts --apply",
    "catalog:verify": "node --env-file=.env --import tsx scripts/verify-catalog-import.ts",
    "catalog:queue-repairs": "node --env-file=.env --import tsx scripts/verify-catalog-import.ts --write-queue",
    "catalog:repair-flows:dry-run": "node --env-file=.env --import tsx scripts/repair-flow-evidence.ts --dry-run",
    "catalog:repair-flows": "node --env-file=.env --import tsx scripts/repair-flow-evidence.ts --apply",
    "storage:migrate": "node --experimental-strip-types scripts/migrate-media-to-objects.ts",
    "storage:verify": "node --experimental-strip-types scripts/verify-object-storage.ts",
    "storage:gc": "node --experimental-strip-types scripts/object-gc.ts",
    "caption": "tsx src/index.ts caption",
    "synthesize": "tsx src/index.ts synthesize",
    "import-flows": "tsx src/index.ts import-flows",
    "research": "tsx src/index.ts research",
    "smart-crawl": "tsx src/index.ts smart-crawl",
    "record": "tsx src/index.ts record",
    "repair-flow": "tsx src/index.ts repair-flow",
    "service:api": "tsx services/api/src/index.ts",
    "service:discover": "tsx services/discover/src/index.ts",
    "service:import-worker": "tsx services/import-worker/src/index.ts",
    "service:antigravity-worker:install": "node scripts/antigravity-worker-launch-agent.mjs install",
    "service:antigravity-worker:status": "node scripts/antigravity-worker-launch-agent.mjs status",
    "service:antigravity-worker:uninstall": "node scripts/antigravity-worker-launch-agent.mjs uninstall",
    "service:search-index-worker": "tsx services/search-index-worker/src/index.ts",
    "service:sites-import-worker": "tsx services/sites-import-worker/src/index.ts",
    "service:public-page-import-worker": "tsx services/public-page-import-worker/src/index.ts",
    "search:index:backfill": "node --env-file=.env --import tsx scripts/search-index-backfill.ts",
    "search:verify-relevance": "node --env-file-if-exists=.env --import tsx scripts/verify-search-relevance.ts",
    "search:benchmark": "node --env-file-if-exists=.env --import tsx scripts/benchmark-search-performance.ts",
    "analysis:pilot:verify": "node --env-file=.env --import tsx scripts/verify-app-knowledge-pilot.ts --app 15five --platform web",
    "test": "node --experimental-strip-types --test --test-concurrency=1 src/*.test.ts src/vitrine/*.test.ts services/api/src/*.test.ts services/import-worker/src/*.test.ts services/sites-import-worker/src/*.test.ts services/public-page-import-worker/src/*.test.ts && tsx --test src/vitrine/*.test.tsx",
    "dev": "vite",
    "build": "vite build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.4",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@stylexjs/stylex": "^0.18.3",
    "amqplib": "^2.0.1",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "pg": "^8.22.0",
    "playwright": "^1.49.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "sharp": "^0.35.3",
    "stripe": "^22.3.1"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "getdesign": "0.6.24",
    "storybook": "^10.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^8.1.3",
    "yaml": "2.9.0"
  }
}
